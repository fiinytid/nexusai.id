{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/chat",              "destination": "/app/chats.html" },
    { "source": "/chats",             "destination": "/app/chats.html" },
    { "source": "/login",             "destination": "/app/login.html" },
    { "source": "/",                  "destination": "/app/index.html" },
    { "source": "/payment",           "destination": "/payment.html" },
    { "source": "/setup-discord-app", "destination": "/app/setup-discord-app.html" },
    { "source": "/privacy",           "destination": "/app/privacy.html" },
    { "source": "/terms",             "destination": "/app/terms.html" },
    { "source": "/admin-panel",       "destination": "/app/admin-panel.html" },
    { "source": "/inbox",             "destination": "/app/inbox.html" },
    { "source": "/ui-editor",         "destination": "/app/chats.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
